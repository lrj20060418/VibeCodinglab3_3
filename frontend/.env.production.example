# 构建「静态文件 + 走云端云函数」时复制为 .env.production（不要提交含真实高德 Key 的文件）
# 与 CloudBase 云函数网关 HTTP 访问路径一致（不要末尾 /）

VITE_CLOUD_PLAN_URL=https://<envId>.service.tcloudbase.com/lab3-plan

# v2.1：静态托管公网地址（用于高德「Web端(JS API)」Key 的域名白名单，不要末尾 /）
# 示例：https://<envId>-<数字>.tcloudbaseapp.com

# 浏览器高德 JS API（仅 Web 端 Key + 安全密钥；勿填 Web 服务 Key）
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_JS_CODE=
