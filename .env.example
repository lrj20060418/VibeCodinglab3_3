# 云函数环境变量（在 CloudBase 控制台配置；plan 云函数需含高德 + LLM，见 README）
# 高德「Web服务」Key（用于 https://restapi.amap.com ，勿填「Web端(JS API)」Key，否则会 USERKEY_PLAT_NOMATCH）
AMAP_WEBSERVICE_KEY=

# 大模型（OpenAI 兼容 chat/completions；AI 摘要路由在 plan 云函数上，故 LLM_* 需配置在 plan）
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# SQLite（每个云函数进程独立 /tmp；仅 plan 持久化规划数据时不必为 weather/chat 配库路径）
# Windows 示例：LAB3_DB_PATH=C:\\data\\lab3-app.db
# Linux/函数内默认：os.tmpdir()/lab3-cloudfunctions/app.db
LAB3_DB_PATH=

# 本地用 node 直接跑 plan/db 时设为 1，可跳过文档库同步（云函数内勿设）
# LAB3_DISABLE_CLOUD_SQLITE=1

# v2.1：浏览器访问来源（静态托管完整 Origin，含 https，无末尾 /）。不填则代码内使用默认托管域名。
# LAB3_HOSTING_ORIGIN=https://your-env-xxxx-0000000000.tcloudbaseapp.com
