# 云函数环境变量（在 CloudBase 控制台为 plan / weather / chat 分别配置，或本地 tcb 模拟时加载）
# 高德天气 Web 服务 Key（仅服务端）
AMAP_WEBSERVICE_KEY=

# 大模型（OpenAI 兼容 chat/completions，仅 chat 云函数必需；plan 的导出/检查里拉天气也会用到 AMAP）
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# SQLite 路径（各云函数实例默认使用系统临时目录下同一文件名即可共享；生产建议改为云数据库）
# Windows 示例：LAB3_DB_PATH=C:\\data\\lab3-app.db
# Linux/函数内默认不写则使用 os.tmpdir()/lab3-cloudfunctions/app.db
LAB3_DB_PATH=
